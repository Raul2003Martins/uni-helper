<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.CadastroMateriaActivity">

    <LinearLayout
        android:layout_width="409dp"
        android:layout_height="729dp"
        android:orientation="vertical"
        tools:layout_editor_absoluteX="1dp"
        tools:layout_editor_absoluteY="1dp">

        <Space
            android:layout_width="match_parent"
            android:layout_height="43dp" />

        <EditText
            android:id="@+id/edtMateria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ems="10"
            android:hint="Nome da Matéria"
            android:inputType="text" />

        <EditText
            android:id="@+id/edtQtdAvaliacoes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ems="10"
            android:hint="Quantidade de avaliações"
            android:inputType="number" />

        <EditText
            android:id="@+id/edtMediaMinima_cadastroMateria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ems="10"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/edtData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="false"
            android:ems="10"
            android:hint="Data da Proxima Prova/Projeto"
            android:inputType="date" />

        <EditText
            android:id="@+id/edtFormula"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ems="10"
            android:hint="Formula de Média da Matéria"
            android:inputType="text"
            android:digits="0123456789Aa+-*/() "/>

        <Space
            android:layout_width="match_parent"
            android:layout_height="309dp" />

        <Button
            android:id="@+id/btnSalvarMateria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:onClick="salvarMateria"
            android:text="Salvar" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>